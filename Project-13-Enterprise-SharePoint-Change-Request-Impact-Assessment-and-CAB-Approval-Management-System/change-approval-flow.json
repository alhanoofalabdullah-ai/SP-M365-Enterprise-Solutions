{
  "flowName": "Enterprise Change Request and CAB Approval Workflow",
  "trigger": {
    "connector": "SharePoint",
    "action": "When an item is created",
    "list": "Enterprise Change Requests"
  },
  "actions": [
    "Generate change number",
    "Set status to Impact Assessment",
    "Evaluate change type and risk level",
