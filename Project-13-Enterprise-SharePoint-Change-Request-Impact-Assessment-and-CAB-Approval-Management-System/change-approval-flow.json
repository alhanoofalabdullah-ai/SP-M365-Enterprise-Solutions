    "Create CAB decision record",
    "Notify requester and implementation team"
  ],
  "changeTypes": [
    "Standard",
    "Normal",
    "Emergency"
  ],
  "riskLevels": [
    "Low",
    "Medium",
    "High",
    "Critical"
  ],
  "failureHandling": [
    "Set status to Processing Failed",
    "Notify change management administrator"
  ]
}
